{
  "name": "neoribbon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:c": "vite --port 3001",
    "dev:s": "bun --hot server/index.ts",
    "dev": "bun concurrently dev:c dev:s",
    "build": "vite build",
    "lint": "bun --bun eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "typecheck": "bun --bun tsc -b --noEmit",
    "prebuild": "bun --tsconfig-override=tsconfig.node.json build server/index.ts --minify --target node --outdir _api",
    "clean": "rm -r _api && rm -r dist && rm -r .vercel"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-router": "^1.133.3",
    "@tanstack/react-router-devtools": "^1.133.3",
    "arktype": "^2.1.23",
    "firebase": "^12.4.0",
    "hono": "^4.9.12",
    "ofetch": "^1.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tanstack/router-plugin": "^1.133.4",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "7.1.17",
    "vite-plugin-vercel": "^9.0.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  }
}
